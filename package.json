{
  "name": "testmigrate-ai",
  "version": "1.0.0",
  "description": "AI-powered test migration and analysis tool",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "nodemon server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "jest",
    "test:e2e": "playwright test",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "keywords": [
    "ai",
    "test",
    "migration",
    "playwright",
    "cypress",
    "testcafe"
  ],
  "author": "Opone Victor",
  "license": "MIT",
  "dependencies": {
    "@monaco-editor/react": "4.6.0",
    "@reduxjs/toolkit": "2.2.3",
    "axios": "1.6.8",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.19.2",
    "helmet": "7.1.0",
    "lucide-react": "0.378.0",
    "morgan": "1.10.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-redux": "9.1.1"
  },
  "devDependencies": {
    "@playwright/test": "1.44.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/express": "4.17.21",
    "@types/jest": "29.5.12",
    "@types/node": "20.12.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "4.3.0",
    "autoprefixer": "10.4.19",
    "concurrently": "8.2.2",
    "jest": "29.7.0",
    "nodemon": "3.1.0",
    "playwright": "1.44.0",
    "postcss": "8.4.38",
    "tailwindcss": "^4.0.0",
    "ts-jest": "29.1.4",
    "typescript": "5.4.5",
    "vite": "^5.2.11"
  }
}